{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "docker compose up --build",
    "prod": "ENVIRONMENT=production nodemon src/app.ts",
    "app:dev": "ENVIRONMENT=development nodemon --inspect=0.0.0.0:9229 --signal SIGINT --nolazy src/app.ts",
    "db:migrations": "ENVIRONMENT=migration ts-node ./src/migrations/runner-cli.ts up",
    "db:migrations:down": "ENVIRONMENT=migration ts-node ./src/migrations/runner-cli.ts down",
    "db:migrations:status": "ENVIRONMENT=migration ts-node ./src/migrations/runner-cli.ts status"
  },
  "keywords": [],
